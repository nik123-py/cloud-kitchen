# ===================================
# Soni Kitchen — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ===================================

# ── Frontend (Vite) ─────────────────────────────
# Admin panel credentials
VITE_ADMIN_USERNAME="cloud kitchen"
VITE_ADMIN_PASSWORD="change-this-to-a-strong-password"

# Supabase (get from supabase.com → Project → Settings → API)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# WhatsApp number for order redirects (country code + number, no + or spaces)
VITE_WHATSAPP_NUMBER="919999999999"

# ── Backend (Vercel Serverless Functions) ────────
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_..."
# ⚠ Service role key — KEEP SECRET, never expose in frontend
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
